    "story_p1": "\u042f \u043d\u0430\u0447\u0430\u043b \u0441\u043e\u0437\u0434\u0430\u0432\u0430\u0442\u044c TripTrack \u043f\u043e\u0441\u043b\u0435 \u0442\u043e\u0433\u043e, \u043a\u0430\u043a Google \u0443\u0434\u0430\u043b\u0438\u043b \u0433\u043e\u0434\u044b \u043c\u043e\u0435\u0439 \u0438\u0441\u0442\u043e\u0440\u0438\u0438 \u043c\u0435\u0441\u0442\u043e\u043f\u043e\u043b\u043e\u0436\u0435\u043d\u0438\u0439 \u0432 \u043d\u0430\u0447\u0430\u043b\u0435 2025 \u0433\u043e\u0434\u0430. \u042f \u0445\u043e\u0442\u0435\u043b \u0432\u0435\u0440\u043d\u0443\u0442\u044c\u0441\u044f \u043a \u0442\u043e\u0439 \u0441\u043f\u043e\u043d\u0442\u0430\u043d\u043d\u043e\u0439 \u043f\u043e\u0435\u0437\u0434\u043a\u0435 \u0432 \u0433\u043e\u0440\u044b, \u043a \u0436\u0438\u0432\u043e\u043f\u0438\u0441\u043d\u043e\u0439 \u043f\u0440\u0438\u0431\u0440\u0435\u0436\u043d\u043e\u0439 \u0434\u043e\u0440\u043e\u0433\u0435 \u043f\u0440\u043e\u0448\u043b\u044b\u043c \u043b\u0435\u0442\u043e\u043c.",
    "story_p2": "\u0411\u044b\u043b\u0438 \u043f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u044f \u0434\u043b\u044f \u0441\u043f\u043e\u0440\u0442\u0441\u043c\u0435\u043d\u043e\u0432. \u0411\u044b\u043b\u0438 \u043f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u044f \u0434\u043b\u044f \u043f\u043b\u0430\u043d\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u044f \u043e\u0442\u043f\u0443\u0441\u043a\u043e\u0432. \u041d\u043e \u043d\u0438\u0447\u0435\u0433\u043e \u0434\u043b\u044f \u043f\u0440\u043e\u0441\u0442\u044b\u0445 \u0435\u0436\u0435\u0434\u043d\u0435\u0432\u043d\u044b\u0445 \u043f\u043e\u0435\u0437\u0434\u043e\u043a. \u0418 \u044f \u0441\u043e\u0437\u0434\u0430\u043b \u0446\u0438\u0444\u0440\u043e\u0432\u043e\u0439 \u0444\u043e\u0442\u043e\u0430\u043b\u044c\u0431\u043e\u043c, \u043e \u043a\u043e\u0442\u043e\u0440\u043e\u043c \u0432\u0441\u0435\u0433\u0434\u0430 \u043c\u0435\u0447\u0442\u0430\u043b.",
    "private_title": "100% \u041f\u0440\u0438\u0432\u0430\u0442\u043d\u043e",
    "private_desc": "\u0414\u0430\u043d\u043d\u044b\u0435 \u043e\u0441\u0442\u0430\u044e\u0442\u0441\u044f \u043d\u0430 \u0412\u0410\u0428\u0415\u041c \u0442\u0435\u043b\u0435\u0444\u043e\u043d\u0435. \u0411\u0435\u0437 \u043e\u0431\u043b\u0430\u043a\u0430. \u0411\u0435\u0437 \u0441\u0435\u0440\u0432\u0435\u0440\u043e\u0432. \u0411\u0435\u0437 \u0440\u0435\u043a\u043b\u0430\u043c\u044b. TripTrack \u0440\u0430\u0431\u043e\u0442\u0430\u0435\u0442 \u043f\u043e\u043b\u043d\u043e\u0441\u0442\u044c\u044e \u043e\u0444\u043b\u0430\u0439\u043d.",
    "indie_title": "\u0418\u043d\u0434\u0438-\u043f\u0440\u043e\u0435\u043a\u0442",
